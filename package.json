{
  "name": "qflow-queue-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "QFlow monorepo for a queue management system for barbershops.",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "install:all": "npm install --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:client": "npm run dev --workspace @qflow/client",
    "dev:server": "npm run dev --workspace @qflow/server",
    "prisma:generate": "npm run prisma:generate --workspace @qflow/server"
  }
}

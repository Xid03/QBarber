{
  "info": {
    "name": "QBarber API",
    "_postman_id": "d37c7706-8a9e-43dd-bfc3-d7aa474c4116",
    "description": "Phase 2 backend foundation for QBarber.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Customer\",\n  \"email\": \"newcustomer@qbarber.demo\",\n  \"phone\": \"+60115556677\",\n  \"password\": \"customer12345\",\n  \"role\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login Owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@qbarber.demo\",\n  \"password\": \"owner12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Operations",
      "item": [
        {
          "name": "List Shops",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/shops",
              "host": ["{{baseUrl}}"],
              "path": ["api", "shops"]
            }
          }
        },
        {
          "name": "Queue Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/queue/status/{{shopId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "queue", "status", "{{shopId}}"]
            }
          }
        },
        {
          "name": "List Bookings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/bookings?shopId={{shopId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings"],
              "query": [
                {
                  "key": "shopId",
                  "value": "{{shopId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Analytics Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/analytics?shopId={{shopId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics"],
              "query": [
                {
                  "key": "shopId",
                  "value": "{{shopId}}"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "jwtToken",
      "value": ""
    },
    {
      "key": "shopId",
      "value": ""
    }
  ]
}
